    "build:android:production": "bash scripts/build-local-android.sh production",
    "build:ios": "bash scripts/build-local-ios.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css}": "prettier --write"
